 176          static void lcd_init(u8 addr, u8 backlight){
 177   1          
 178   1        lcd._backlight = backlight ? LCD_BACKLIGHT : LCD_NOBACKLIGHT;
 179   1        lcd._addr = addr << 1; //i2c uses 7 bits for address 
 180   1        PCF8574_Write(lcd._backlight);
 181   1        DelayXms(10);
 182   1        
 183   1        //starting generator
 184   1        write4bit(0x30); DelayXus(150); //first pull
 185   1        write4bit(0x30); DelayXus(150); //second pull
 186   1        write4bit(0x30); DelayXus(150); //third pull
 187   1        
 188   1        write4bit(0x20); //pressing power button
 189   1        //generator on!
 190   1      
 191   1        DelayXus(150);
 192   1        command(0x28);  //4 BIT MODE, 2 LINE, 5X8 DOTS 
 193   1        lcd._displayctrl = LCD_DISPLAYCONTROL | LCD_DISPLAYON | LCD_CURSOROFF | LCD_BLINKOFF; 
 194   1        command(0x0c);  //display on, cursor off, blink off
 195   1        command(LCD_CLEARDISPLAY);
 196   1        DelayXms(2); //clearing takes time 
 197   1        lcd._displaymode = LCD_ENTRYMODESET| LCD_ENTRYLEFT | LCD_ENTRYSHIFTDECREMENT;
 198   1        
 199   1        command(LCD_SETDDRAMADDR);  
 200   1        
 201   1      }
