 159          static void send(u8 dataC, u8 mode){
 160   1          u8 highNibble = dataC & 0xF0; 
 161   1          u8 lowNibble = (dataC << 4) & 0xF0;
 162   1          write4bit((highNibble) | mode);
 163   1          write4bit((lowNibble) | mode);
 164   1      }
